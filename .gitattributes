# Normalize line endings. Go tooling (gofmt) expects LF.
* text=auto eol=lf

*.go      text eol=lf
*.mod     text eol=lf
*.sum     text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.svg     text eol=lf
Makefile  text eol=lf

# Windows-only helper scripts keep CRLF
*.bat     text eol=crlf
*.ps1     text eol=crlf

# Binary assets (none yet, but be explicit)
*.png     binary
*.jpg     binary
*.gif     binary
*.ico     binary
